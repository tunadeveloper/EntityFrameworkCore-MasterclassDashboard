@using EntityFrameworkCore_MasterclassDashboard.Entities
@{
    ViewData["Title"] = "Yeni Sipariş Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model Order
<main id="content" class="content py-10">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex align-items-center gap-2">
                    <a href="@Url.Action("Index", "Order")" class="btn btn-outline-secondary btn-sm rounded-2">
                        <i class="ti ti-arrow-left"></i>
                    </a>
                    <div>
                        <h1 class="fs-3 mb-1">Yeni Sipariş Ekle</h1>
                        <p class="text-muted mb-0">Sipariş bilgilerini girin.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-6">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm">
                    <div class="card-header bg-light bg-opacity-50 border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-shopping-cart-plus me-2 text-primary"></i>Sipariş Bilgileri</h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" action="@Url.Action("CreateOrder", "Order")">
                            <div class="mb-4">
                                <label for="ProductId" class="form-label fw-semibold">Ürün <span class="text-danger">*</span></label>
                                <select name="ProductId" id="ProductId" class="form-select rounded-2" asp-items="ViewBag.productList" required>
                                    <option value="">--- Ürün Seçiniz ---</option>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label for="CustomerId" class="form-label fw-semibold">Müşteri <span class="text-danger">*</span></label>
                                <select name="CustomerId" id="CustomerId" class="form-select rounded-2" asp-items="ViewBag.customerList" required>
                                    <option value="">--- Müşteri Seçiniz ---</option>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label for="SaleCount" class="form-label fw-semibold">Satış Adedi <span class="text-danger">*</span></label>
                                <input type="text" name="SaleCount" id="SaleCount" class="form-control rounded-2" placeholder="0" min="1">
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label for="UnitPrice" class="form-label fw-semibold">Birim Fiyat (₺) <span class="text-danger">*</span></label>
                                    <input type="text" step="0.01" name="UnitPrice" id="UnitPrice" class="form-control rounded-2" placeholder="0,00">
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label for="TotalPrice" class="form-label fw-semibold">Toplam Fiyat (₺) <span class="text-danger">*</span></label>
                                    <input type="text" step="0.01" name="TotalPrice" id="TotalPrice" class="form-control rounded-2" placeholder="0,00">
                                </div>
                            </div>
                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" asp-for="IsActive" />
                                    <label class="form-check-label" asp-for="IsActive">Aktif</label>
                                </div>
                            </div>
                            <hr class="my-4">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary rounded-2">
                                    <i class="ti ti-check me-1"></i> Kaydet
                                </button>
                                <a href="@Url.Action("Index", "Order")" class="btn btn-outline-secondary rounded-2">İptal</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
