@using EntityFrameworkCore_MasterclassDashboard.Entities
@{
    ViewData["Title"] = "Yeni Kategori Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model Category
<main id="content" class="content py-10">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex align-items-center gap-2">
                    <a href="@Url.Action("Index", "Category")" class="btn btn-outline-secondary btn-sm rounded-2">
                        <i class="ti ti-arrow-left"></i>
                    </a>
                    <div>
                        <h1 class="fs-3 mb-1">Yeni Kategori Ekle</h1>
                        <p class="text-muted mb-0">Kategori bilgilerini girin.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-6">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm">
                    <div class="card-header bg-light bg-opacity-50 border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-category me-2 text-primary"></i>Kategori Bilgileri</h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" action="@Url.Action("CreateCategory", "Category")">
                            <div class="mb-4">
                                <label for="CategoryName" class="form-label fw-semibold">Kategori Adı <span class="text-danger">*</span></label>
                                <input type="text" name="CategoryName" id="CategoryName" class="form-control rounded-2" placeholder="Örn. Elektronik">
                            </div>
                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" asp-for="IsActive" />
                                    <label class="form-check-label" asp-for="IsActive">Aktif</label>
                                </div>
                            </div>
                            <hr class="my-4">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary rounded-2">
                                    <i class="ti ti-check me-1"></i> Kaydet
                                </button>
                                <a href="@Url.Action("Index", "Category")" class="btn btn-outline-secondary rounded-2">İptal</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
