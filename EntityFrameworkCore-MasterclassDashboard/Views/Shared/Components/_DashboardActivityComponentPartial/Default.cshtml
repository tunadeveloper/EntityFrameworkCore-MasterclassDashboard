@using EntityFrameworkCore_MasterclassDashboard.Entities
@model List<Activity>
<div class="row g-3 mt-3">
    <div class="col-lg-12">
        <div class="card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="icon-shape icon-sm bg-primary text-white rounded-2 d-inline-flex align-items-center justify-content-center">
                        <i class="ti ti-activity"></i>
                    </span>
                    <div>
                        <h4 class="mb-0 h5">Son Aktiviteler</h4>
                        <small class="text-muted">Sistem ve kullanıcı hareketlerinin özeti</small>
                    </div>
                </div>
                <button class="btn btn-sm btn-outline-secondary">
                    <i class="ti ti-calendar-event me-1"></i> Bugün
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="ps-4">Başlık</th>
                                <th scope="col">Açıklama</th>
                                <th scope="col">Saat</th>
                                <th scope="col">Tür</th>
                                <th scope="col" class="pe-4 text-end">Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@item.ActivityTitle</span>
                                            <small class="text-muted">@item.ActivitySubTitle</small>
                                        </div>
                                    </td>
                                    <td>@item.ActivityDescription</td>
                                    <td><span class="badge bg-light text-dark">@item.CreatedDate.ToString("HH:mm")</span></td>
                                    <td>
                                        @switch (item.ActivityType)
                                        {
                                            case "Müşteri":
                                                <span class="badge bg-success-subtle text-success border border-success">
                                                    <i class="ti ti-user-plus me-1"></i> Müşteri
                                                </span>
                                                break;
                                                case "Ödeme":
                                                <span class="badge bg-warning-subtle text-warning border border-warning">
                                                    <i class="ti ti-credit-card me-1"></i> Ödeme
                                                </span>
                                                break;
                                            case "Uyarı":
                                                <span class="badge bg-danger-subtle text-danger border border-danger">
                                                    <i class="ti ti-alert-triangle me-1"></i> Uyarı
                                                </span>
                                                break;
                                            case "Stok":
                                                <span class="badge bg-info-subtle text-info border border-info">
                                                    <i class="ti ti-package-export me-1"></i> Stok
                                                </span>
                                                break;
                                                default:
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary">
                                                    <i class="ti ti-package-export me-1"></i> Diğer
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td class="pe-4 text-end text-muted">@item.CreatedDate.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

