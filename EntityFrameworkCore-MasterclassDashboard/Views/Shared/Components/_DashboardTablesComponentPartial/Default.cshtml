@using EntityFrameworkCore_MasterclassDashboard.Entities
@{
    var bestSellingProductsList = ViewBag.bestSellingProductsList as List<Order>;
    var lowStockProducts = ViewBag.lowStockProducts as List<Product>;
    var latestSales = ViewBag.latestSales as List<Order>;
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card  h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
                <h4 class="mb-0 h5">En Çok Satan Ürünler</h4>
                <button class="btn btn-sm btn-outline-secondary">
                    <i class="ti ti-calendar"></i> Bugün
                </button>
            </div>
            ViewBag.lowStockProducts
                <ul class="list-group list-group-flush">
                @foreach (var item in bestSellingProductsList)
                {
                    <li class="list-group-item d-flex align-items-center gap-3">
                        <img src="/inapp-1.0.0/src/assets/images/product-8.png" class="rounded" width="48">
                        <div class="flex-grow-1">
                            <p class="mb-1 fw-bold">@item.Product.ProductName</p>
                            <div class="d-flex align-items-center gap-2 text-muted">
                                <small class="fw-semibold">₺@item.UnitPrice</small>
                                <small>•</small>
                                <small>@item.SaleCount Adet</small>
                            </div>
                        </div>
                        <span class="badge bg-warning-subtle text-warning border border-warning">stok: @item.Product.ProductStock</span>
                    </li>
                }
                </ul>
            
           
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card  h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
                <div class="d-flex align-items-center">
                    <h4 class="mb-0 h5">Az Stoklu Ürünler</h4>
                </div>
                <a href="#" class="small text-primary text-decoration-underline">Tümünü Gör</a>
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var item in lowStockProducts)
                {
                    <li class="list-group-item d-flex align-items-center gap-3">
                        <img src="/inapp-1.0.0/src/assets/images/product-8.png" class="rounded" width="48">
                        <div class="flex-grow-1">
                            <p class="mb-1">@item.ProductName</p>
                            <small>Fiyat: @item.ProductPrice.ToString("N2")</small>
                        </div>
                        <div class="d-flex flex-column gap-0 align-items-center">
                            <span class="fw-semibold text-primary">@item.ProductStock</span>
                            <small class="text-muted">Stokta</small>
                        </div>
                    </li>
                }
               
            </ul>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card  h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
                <h4 class="mb-0 h5">Son Satışlar</h4>
                <button class="btn btn-sm btn-outline-secondary">
                    <i class="ti ti-calendar-event"></i> Haftalık
                </button>
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var item in latestSales)
                {
                    <li class="list-group-item d-flex align-items-center gap-3">
                        <img src="/inapp-1.0.0/src/assets/images/product-7.png" class="rounded" width="48">
                        <div class="flex-grow-1">
                            <p class="mb-1">@item.Product.ProductName</p>
                            <div class="d-flex align-items-center gap-2 text-muted">
                                <small class="fw-semibold">@item.Product.Category.CategoryName</small>
                                <small>•</small>
                                <small>₺@item.Product.ProductPrice</small>
                            </div>
                        </div>
                        <span class="badge bg-warning-subtle text-warning border border-warning">stok: @item.Product.ProductStock</span>
                    </li>
                }

            </ul>
        </div>
    </div>
</div>
