@{
    ViewData["Title"] = "EF Core Ödev Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main id="content" class="content py-10">
<div class="container-fluid">

    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <h1 class="fs-3 mb-1">EntityFramework Core Methodları</h1>
                    <p class="text-muted mb-0">Her metod için hazırlanmış pratik ödevler — kodu kendin yaz, algoritmayı kendin geliştir.</p>
                </div>
                <div class="d-flex gap-2">
                    <span class="badge bg-primary rounded-pill px-3 py-2 fs-6"><i class="ti ti-list-check me-1"></i> 62 Method</span>
                    <span class="badge bg-success rounded-pill px-3 py-2 fs-6"><i class="ti ti-category-2 me-1"></i> 8 Grup</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-2"><div class="col-12"><div class="d-flex align-items-center gap-2 mb-3">
        <div class="icon-shape icon-md bg-primary text-white rounded-2 d-flex align-items-center justify-content-center"><i class="ti ti-pencil fs-5"></i></div>
        <div><h5 class="fw-bold text-primary mb-0">Grup 1 — Temel CRUD İşlemleri</h5><small class="text-muted">ToList · Add · Find · Remove · Update · SaveChanges</small></div>
    </div></div></div>
    <div class="row g-3 mb-5">
        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-primary border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-primary rounded-2 fs-6 px-2 py-1 mt-1">01</span>
            <div><code class="text-primary fw-bold">.ToList()</code>
            <p class="text-muted small mt-1 mb-2">Veritabanındaki tüm ürünleri listeye çek ve her birinin adını konsola yazdır.</p>
                            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,110,253,.10);color:#0d6efd;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0d6efd;flex-shrink:0;"></span>@ViewBag.productList kayıt listelendi</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-primary border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-primary rounded-2 fs-6 px-2 py-1 mt-1">02</span>
            <div><code class="text-primary fw-bold">.Add() &amp; .SaveChanges()</code>
            <p class="text-muted small mt-1 mb-2">Yeni bir ürün nesnesi oluştur, DbSet'e ekle ve değişiklikleri veritabanına kaydet.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,110,253,.10);color:#0d6efd;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0d6efd;flex-shrink:0;"></span>"Laptop" eklendi</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-primary border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-primary rounded-2 fs-6 px-2 py-1 mt-1">03</span>
            <div><code class="text-primary fw-bold">.Find()</code>
            <p class="text-muted small mt-1 mb-2">Id değerine göre ilgili müşteriyi bul ve bilgilerini görüntüle.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,110,253,.10);color:#0d6efd;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0d6efd;flex-shrink:0;"></span>@ViewBag.findCustomer</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-primary border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-primary rounded-2 fs-6 px-2 py-1 mt-1">04</span>
            <div><code class="text-primary fw-bold">.Remove() &amp; .SaveChanges()</code>
            <p class="text-muted small mt-1 mb-2">Id'ye sahip siparişi bul, sil ve işlemi veritabanına yansıt.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,110,253,.10);color:#0d6efd;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0d6efd;flex-shrink:0;"></span>Sipariş #12 silindi</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-primary border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-primary rounded-2 fs-6 px-2 py-1 mt-1">05</span>
            <div><code class="text-primary fw-bold">.Update() &amp; .SaveChanges()</code>
            <p class="text-muted small mt-1 mb-2">Belirli bir ürünün adını ve fiyatını güncelle, ardından değişikliği kaydet.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,110,253,.10);color:#0d6efd;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0d6efd;flex-shrink:0;"></span>Fiyat ₺299 → ₺349</span>
            </div></div></div></div>
    </div>

    <div class="row mb-2"><div class="col-12"><div class="d-flex align-items-center gap-2 mb-3">
        <div class="icon-shape icon-md bg-success text-white rounded-2 d-flex align-items-center justify-content-center"><i class="ti ti-calculator fs-5"></i></div>
        <div><h5 class="fw-bold text-success mb-0">Grup 2 — Agregasyon / İstatistik</h5><small class="text-muted">Count · Min · Max · Sum · Average · LongCount · CountBy</small></div>
    </div></div></div>
    <div class="row g-3 mb-5">
        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-success border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-success rounded-2 fs-6 px-2 py-1 mt-1">06</span>
            <div><code class="text-success fw-bold">.Count()</code>
            <p class="text-muted small mt-1 mb-2">Veritabanında kaç adet aktif ürün bulunduğunu hesapla.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(25,135,84,.10);color:#198754;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#198754;flex-shrink:0;"></span>@ViewBag.activeCount adet</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-success border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-success rounded-2 fs-6 px-2 py-1 mt-1">07</span>
            <div><code class="text-success fw-bold">.Min()</code>
            <p class="text-muted small mt-1 mb-2">Tüm ürünler arasında en düşük fiyatlı olanı bul.</p>
                            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(25,135,84,.10);color:#198754;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#198754;flex-shrink:0;"></span>Minimum: ₺@ViewBag.lowPriceProduct</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-success border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-success rounded-2 fs-6 px-2 py-1 mt-1">08</span>
            <div><code class="text-success fw-bold">.Max()</code>
            <p class="text-muted small mt-1 mb-2">Tüm müşteriler arasında en yüksek bakiyeye sahip olanı bul.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(25,135,84,.10);color:#198754;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#198754;flex-shrink:0;"></span>Max: ₺@ViewBag.highBalanceCustomer</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-success border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-success rounded-2 fs-6 px-2 py-1 mt-1">09</span>
            <div><code class="text-success fw-bold">.Sum()</code>
            <p class="text-muted small mt-1 mb-2">Tüm siparişlerin toplam gelirini (TotalPrice) hesapla.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(25,135,84,.10);color:#198754;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#198754;flex-shrink:0;"></span>Toplam: ₺@ViewBag.totalCustomerBalance</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-success border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-success rounded-2 fs-6 px-2 py-1 mt-1">10</span>
            <div><code class="text-success fw-bold">.Average()</code>
            <p class="text-muted small mt-1 mb-2">Ürün stoklarının ortalamasını hesapla ve görüntüle.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(25,135,84,.10);color:#198754;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#198754;flex-shrink:0;"></span>Ortalama: @ViewBag.avgProductStock</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-success border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-success rounded-2 fs-6 px-2 py-1 mt-1">11</span>
            <div><code class="text-success fw-bold">.LongCount()</code>
            <p class="text-muted small mt-1 mb-2">Toplam sipariş sayısını <em>long</em> veri tipiyle döndür.</p>
                            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(25,135,84,.10);color:#198754;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#198754;flex-shrink:0;"></span>@ViewBag.totalOrderLong sipariş</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-success border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-success rounded-2 fs-6 px-2 py-1 mt-1">12</span>
            <div><code class="text-success fw-bold">.CountBy()</code>
            <p class="text-muted small mt-1 mb-2">Ürünleri IsActive alanına göre grupla; her grupta kaç ürün olduğunu listele.</p>
                            @foreach (var item in ViewBag.productActiveGroups)
                            {
                                <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold"
                                      style="background:rgba(25,135,84,.10);color:#198754;font-size:11px;">

                                    <span style="width:7px;height:7px;border-radius:50%;background:#198754;flex-shrink:0;"></span>

                                    @if (item.Key == true)
                                    {
                                        @:Aktif:@item.Value
                                    }
                                    else 
                                    {
                                        @:Pasif:@item.Value
                                    }
                                </span>
                            }
            </div></div></div></div>
    </div>

    <div class="row mb-2"><div class="col-12"><div class="d-flex align-items-center gap-2 mb-3">
        <div class="icon-shape icon-md bg-info text-white rounded-2 d-flex align-items-center justify-content-center"><i class="ti ti-filter fs-5"></i></div>
        <div><h5 class="fw-bold text-info mb-0">Grup 3 — Sorgulama / Filtreleme</h5><small class="text-muted">Where · Select · Include · FirstOrDefault · First · Last · SingleOrDefault · Any · All · Contains · StartsWith · EndsWith · AsQueryable · AsNoTracking · DefaultIfEmpty</small></div>
    </div></div></div>
    <div class="row g-3 mb-5">
        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">13</span>
            <div><code class="text-info fw-bold">.Where()</code>
            <p class="text-muted small mt-1 mb-2">Stok miktarı 50'nin üzerinde olan aktif ürünleri filtrele.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@ViewBag.filteredProducts kayıt</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">14</span>
            <div><code class="text-info fw-bold">.Select()</code>
            <p class="text-muted small mt-1 mb-2">Tüm siparişlerden yalnızca ürün adı ve toplam fiyat bilgisini seç.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@ViewBag.orderSummary kayıt</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">15</span>
            <div><code class="text-info fw-bold">.Include()</code>
            <p class="text-muted small mt-1 mb-2">Siparişleri hem ürün hem de müşteri bilgileriyle birlikte getir.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@ViewBag.ordersWithDetails kayıt</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">16</span>
            <div><code class="text-info fw-bold">.FirstOrDefault()</code>
            <p class="text-muted small mt-1 mb-2">Fiyatı 1000 TL'nin üzerinde olan ilk ürünü bul; yoksa null döndür.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@ViewBag.firstExpensiveProduct</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">17</span>
            <div><code class="text-info fw-bold">.First()</code>
            <p class="text-muted small mt-1 mb-2">Kayıtlardaki ilk müşteriyi getir; bulunamazsa exception fırlat.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@ViewBag.firstCustomer</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">18</span>
            <div><code class="text-info fw-bold">.Last()</code>
            <p class="text-muted small mt-1 mb-2">En son eklenen siparişi (Id'ye göre sıralayarak) bul.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>Sipariş #@(((dynamic)ViewBag.lastOrder)?.Id)</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">19</span>
            <div><code class="text-info fw-bold">.SingleOrDefault()</code>
            <p class="text-muted small mt-1 mb-2">Adı tam olarak 'Laptop' olan tek ürünü bul; yoksa null döndür.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@(((dynamic)ViewBag.singleProduct)?.ProductName)</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">20</span>
            <div><code class="text-info fw-bold">.Any()</code>
            <p class="text-muted small mt-1 mb-2">Toplam fiyatı 5000 TL'nin üzerinde olan sipariş var mı? Kontrol et.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@ViewBag.hasExpensiveOrder</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">21</span>
            <div><code class="text-info fw-bold">.All()</code>
            <p class="text-muted small mt-1 mb-2">Tüm ürünlerin IsActive alanı true mu? Doğrula.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@ViewBag.allProductsActive</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">22</span>
            <div><code class="text-info fw-bold">.Contains()</code>
            <p class="text-muted small mt-1 mb-2">Ürün adları listesinde 'Kulaklık' değeri var mı? Kontrol et.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>@(((IQueryable<dynamic>)ViewBag.containsHeadphone).Count()) eşleşme</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">23</span>
            <div><code class="text-info fw-bold">.StartsWith()</code>
            <p class="text-muted small mt-1 mb-2">Adı 'A' harfiyle başlayan tüm müşterileri listele.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>7 kayıt</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">24</span>
            <div><code class="text-info fw-bold">.EndsWith()</code>
            <p class="text-muted small mt-1 mb-2">Şehir adı 'i' ile biten müşterileri filtrele.</p>
            <span class="d-inline-flex align-items-center gap-1 rounded-1 px-2 py-1 fw-semibold" style="background:rgba(13,202,240,.12);color:#0aa2c0;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#0dcaf0;flex-shrink:0;"></span>12 kayıt</span>
            </div></div></div></div>

        <div class="col-lg-2 col-md-4 col-6"><div class="card p-3 h-100 border border-info border-opacity-25 rounded-2"><div class="d-flex align-items-start gap-3">
            <span class="badge bg-info rounded-2 fs-6 px-2 py-1 mt-1">25</span>
            <div><code class="text-info fw-bold">.AsQueryable()</code>
            <p class="text-muted small mt-1 mb-2">Ürün sorgusunu IQueryable olarak başlat; koşullu aktiflik filtresi ekle.</p>
