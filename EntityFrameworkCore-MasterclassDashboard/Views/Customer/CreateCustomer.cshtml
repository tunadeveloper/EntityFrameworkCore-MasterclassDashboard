@using EntityFrameworkCore_MasterclassDashboard.Entities
@{
    ViewData["Title"] = "Yeni Müşteri Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model Customer
<main id="content" class="content py-10">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex align-items-center gap-2">
                    <a href="@Url.Action("Index", "Customer")" class="btn btn-outline-secondary btn-sm rounded-2">
                        <i class="ti ti-arrow-left"></i>
                    </a>
                    <div>
                        <h1 class="fs-3 mb-1">Yeni Müşteri Ekle</h1>
                        <p class="text-muted mb-0">Müşteri bilgilerini girin.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-6">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm">
                    <div class="card-header bg-light bg-opacity-50 border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-user-plus me-2 text-primary"></i>Müşteri Bilgileri</h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" action="@Url.Action("CreateCustomer", "Customer")">
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label for="CustomeName" class="form-label fw-semibold">Ad <span class="text-danger">*</span></label>
                                    <input type="text" name="CustomeName" id="CustomeName" class="form-control rounded-2" placeholder="Örn. Ahmet">
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label for="CustomeSurname" class="form-label fw-semibold">Soyad <span class="text-danger">*</span></label>
                                    <input type="text" name="CustomeSurname" id="CustomeSurname" class="form-control rounded-2" placeholder="Örn. Yılmaz">
                                </div>
                            </div>
                            <div class="mb-4">
                                <label for="CustomerImageUrl" class="form-label fw-semibold">Profil Resmi URL</label>
                                <input type="text" name="CustomerImageUrl" id="CustomerImageUrl" class="form-control rounded-2" placeholder="https://...">
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label for="CustomeCity" class="form-label fw-semibold">Şehir <span class="text-danger">*</span></label>
                                    <input type="text" name="CustomeCity" id="CustomeCity" class="form-control rounded-2" placeholder="Örn. İstanbul">
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label for="CustomeDistrict" class="form-label fw-semibold">İlçe</label>
                                    <input type="text" name="CustomeDistrict" id="CustomeDistrict" class="form-control rounded-2" placeholder="Örn. Kadıköy">
                                </div>
                            </div>
                            <div class="mb-4">
                                <label for="CustomeBalance" class="form-label fw-semibold">Bakiye (₺) <span class="text-danger">*</span></label>
                                <input type="text" step="0.01" name="CustomeBalance" id="CustomeBalance" class="form-control rounded-2" placeholder="0,00" min="0">
                            </div>
                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" asp-for="IsActive" />
                                    <label class="form-check-label" asp-for="IsActive">Aktif</label>
                                </div>
                            </div>
                            <hr class="my-4">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary rounded-2">
                                    <i class="ti ti-check me-1"></i> Kaydet
                                </button>
                                <a href="@Url.Action("Index", "Customer")" class="btn btn-outline-secondary rounded-2">İptal</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
