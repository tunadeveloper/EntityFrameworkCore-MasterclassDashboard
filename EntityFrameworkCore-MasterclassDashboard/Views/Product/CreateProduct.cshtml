@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main id="content" class="content py-10">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex align-items-center gap-2">
                    <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary btn-sm rounded-2">
                        <i class="ti ti-arrow-left"></i>
                    </a>
                    <div>
                        <h1 class="fs-3 mb-1">Yeni Ürün Ekle</h1>
                        <p class="text-muted mb-0">Ürün bilgilerini girin.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8 col-xl-6">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm">
                    <div class="card-header bg-light bg-opacity-50 border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-package me-2 text-primary"></i>Ürün Bilgileri</h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" action="@Url.Action("CreateProduct", "Product")">
                            @Html.AntiForgeryToken()
                            <div class="mb-4">
                                <label for="ProductName" class="form-label fw-semibold">Ürün Adı <span class="text-danger">*</span></label>
                                <input type="text" name="ProductName" id="ProductName" class="form-control rounded-2" placeholder="Örn. Kablosuz Kulaklık" value="">
                            </div>
                            <div class="mb-4">
                                <label for="ProductPrice" class="form-label fw-semibold">Fiyat (₺) <span class="text-danger">*</span></label>
                                <input type="number" step="0.01" name="ProductPrice" id="ProductPrice" class="form-control rounded-2" placeholder="0,00" value="">
                            </div>
                            <div class="mb-4">
                                <label for="ProductStock" class="form-label fw-semibold">Stok Miktarı <span class="text-danger">*</span></label>
                                <input type="number" name="ProductStock" id="ProductStock" class="form-control rounded-2" placeholder="0" value="" min="0">
                            </div>
                            <div class="mb-4">
                                <label for="CategoryId" class="form-label fw-semibold">Kategori</label>
                                <select name="CategoryId" id="CategoryId" class="form-select rounded-2">
                                    <option value="1">Elektronik</option>
                                    <option value="2">Giyim</option>
                                    <option value="3">Ev & Yaşam</option>
                                </select>
                            </div>
                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="IsActive" id="IsActive" value="true" checked>
                                    <label class="form-check-label" for="IsActive">Aktif</label>
                                </div>
                            </div>
                            <hr class="my-4">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary rounded-2">
                                    <i class="ti ti-check me-1"></i> Kaydet
                                </button>
                                <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary rounded-2">İptal</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
