@using EntityFrameworkCore_MasterclassDashboard.Entities
@using X.PagedList
@using X.PagedList.Mvc.Core
@{
    ViewData["Title"] = "Ürün Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model IPagedList<Product>
<main id="content" class="content py-10">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div class="mb-6">
                        <h1 class="fs-3 mb-1">Ürün Listesi</h1>
                        <p class="text-muted mb-0">Tüm ürünleri görüntüleyin ve yönetin.</p>
                    </div>
                    <a href="/Product/CreateProduct" class="btn btn-primary rounded-2">
                        <i class="ti ti-plus me-1"></i> Yeni Ürün Ekle
                    </a>
                </div>
            </div>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-lg-4 col-12">
                <div class="card p-4 bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-2 h-100">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md bg-primary text-white rounded-2 d-flex align-items-center justify-content-center">
                            <i class="ti ti-package fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6 text-muted">Toplam Ürün</h2>
                            <h3 class="fw-bold mb-0">@ViewBag.totalProduct</h3>
                            <p class="text-primary mb-0 small">Kayıtlı ürün sayısı</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-12">
                <div class="card p-4 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-2 h-100">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md bg-success text-white rounded-2 d-flex align-items-center justify-content-center">
                            <i class="ti ti-stack-2 fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6 text-muted">Toplam Stok</h2>
                            <h3 class="fw-bold mb-0">@ViewBag.totalStock</h3>
                            <p class="text-success mb-0 small">Toplam adet</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-12">
                <div class="card p-4 bg-info bg-opacity-10 border border-info border-opacity-25 rounded-2 h-100">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md bg-info text-white rounded-2 d-flex align-items-center justify-content-center">
                            <i class="ti ti-currency-lira fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6 text-muted">Ortalama Fiyat</h2>
                            <h3 class="fw-bold mb-0">₺@ViewBag.avgPrice</h3>
                            <p class="text-info mb-0 small">Ürün başına</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm overflow-hidden">
                    <div class="card-header bg-light bg-opacity-50 border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-list me-2 text-primary"></i>Ürünler</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="border-0 ps-4">Id</th>
                                        <th class="border-0">Ürün Adı</th>
                                        <th class="border-0">Fiyat</th>
                                        <th class="border-0">Stok</th>
                                        <th class="border-0">Kategori Id</th>
                                        <th class="border-0">Oluşturulma</th>
                                        <th class="border-0">Durum</th>
                                        <th class="border-0 pe-4 text-end">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">@item.Id</td>
                                            <td>@item.ProductName</td>
                                            <td>₺@item.ProductPrice.ToString("N2")</td>
                                            <td>@item.ProductStock</td>
                                            <td>@item.Category.CategoryName</td>
                                            <td><small class="text-muted">@item.CreatedDate.ToString("dd MMM yyyy")</small></td>
                                            <td><span class="badge bg-@(item.IsActive ? "success" : "danger") rounded-pill">@(item.IsActive ? "Aktif" : "Pasif")</span></td>
                                            <td class="pe-4 text-end">
                                                <a href="/Product/UpdateProduct/@item.Id" class="btn btn-sm btn-outline-primary rounded-2 me-1"><i class="ti ti-edit"></i></a>
                                                <a href="/Product/DeleteProduct/@item.Id" class="btn btn-sm btn-outline-danger rounded-2"><i class="ti ti-trash"></i></a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="card-footer bg-white border-top border-secondary border-opacity-25 px-4 py-3 d-flex flex-wrap align-items-center justify-content-between gap-3">
                            <div class="d-flex align-items-center gap-2 text-muted small">
                                <span class="rounded-1 bg-primary bg-opacity-10 px-2 py-1">
                                    <i class="ti ti-package text-primary"></i>
                                </span>
                                <span>Toplam <strong class="text-dark">@ViewBag.totalProduct</strong> ürün listeleniyor</span>
                            </div>
                            <nav aria-label="Sayfa navigasyonu">
                                @Html.PagedListPager(Model, page => Url.Action(nameof(Index), new { page }), new PagedListRenderOptions
                                {
                                    UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0", "justify-content-end" },
                                    LiElementClasses = new[] { "page-item" },
                                    PageClasses = new[] { "page-link" },
                                    ActiveLiElementClass = "active"
                                })
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
