@using EntityFrameworkCore_MasterclassDashboard.Entities
@{
    ViewData["Title"] = "Müşteri İstatistikleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cityStats = ViewBag.cityBalanceStats as Dictionary<string, int>;
    var customers = ViewBag.highBalanceCustomer as List<Customer>;
}

<main id="content" class="content py-10">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="mb-6">
                    <h1 class="fs-3 mb-1">Müşteri İstatistikleri</h1>
                    <p class="text-muted mb-0">Bakiye, şehir ve müşteri özeti</p>
                </div>
            </div>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card border border-secondary border-opacity-25 rounded-3 shadow-sm overflow-hidden">
                    <div class="card-header bg-light bg-opacity-50 border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-dashboard me-2 text-primary"></i>Müşteri Özeti</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="row g-0">
                            <div class="col-6 col-lg-3 border-end border-bottom border-secondary border-opacity-25 p-4 text-center">
                                <i class="ti ti-users-group fs-2 text-primary d-block mb-2"></i>
                                <span class="d-block fs-2 fw-bold text-primary">@ViewBag.totalCustomers</span>
                                <small class="text-muted">Toplam Müşteri</small>
                            </div>
                            <div class="col-6 col-lg-3 border-end border-bottom border-secondary border-opacity-25 p-4 text-center">
                                <i class="ti ti-wallet fs-2 text-success d-block mb-2"></i>
                                <span class="d-block fs-2 fw-bold text-success">₺@ViewBag.totalBalance</span>
                                <small class="text-muted">Toplam Bakiye</small>
                            </div>
                            <div class="col-6 col-lg-3 border-end border-secondary border-opacity-25 p-4 text-center">
                                <i class="ti ti-chart-bar fs-2 text-info d-block mb-2"></i>
                                <span class="d-block fs-2 fw-bold text-info">₺@ViewBag.avgBalance</span>
                                <small class="text-muted">Ortalama Bakiye</small>
                            </div>
                            <div class="col-6 col-lg-3 p-4 text-center">
                                <i class="ti ti-arrow-up fs-2 text-warning d-block mb-2"></i>
                                <span class="d-block fs-2 fw-bold text-warning">₺@ViewBag.highBalance</span>
                                <small class="text-muted">En Yüksek Bakiye</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-lg-5 col-12">
                <div class="card border border-secondary border-opacity-25 rounded-3 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4"><i class="ti ti-currency-lira me-2 text-success"></i>Bakiye Aralığı</h5>
                        <div class="d-flex justify-content-between align-items-center rounded-2 bg-primary bg-opacity-10 border border-primary border-opacity-25 p-3 mb-3">
                            <span class="text-muted">En Düşük Bakiye</span>
                            <span class="fw-bold fs-4 text-primary">₺@ViewBag.lowBalance</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center rounded-2 bg-success bg-opacity-10 border border-success border-opacity-25 p-3">
                            <span class="text-muted">En Yüksek Bakiye</span>
                            <span class="fw-bold fs-4 text-success">₺@ViewBag.highBalance</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7 col-12">
                <div class="card border border-secondary border-opacity-25 rounded-3 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-map-pin me-2 text-info"></i>En yüksek bakiyeye sahip şehirler ve şehirlere ait kişi sayısı</h5>
                    </div>
                    <div class="card-body p-3">
                        <div class="row g-2">
                            @foreach(var item in cityStats)
                            {
                                <div class="col-6 col-md-4">
                                    <div class="rounded-2 border border-secondary border-opacity-25 p-2 text-center">
                                        <span class="d-block fw-bold text-info">@item.Value</span>
                                        <span class="badge bg-info rounded-pill">@item.Key</span>
                                    </div>
                                </div>
                            }
                            
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <div class="card border border-secondary border-opacity-25 rounded-3 shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-user-circle me-2 text-primary"></i>Müşteri Listesi</h5>
                        <button class="btn btn-sm btn-outline-primary rounded-2"><i class="ti ti-search me-1"></i>Ara</button>
                    </div>
                    <div class="card-body p-3">
                        <div class="row g-3">
                            @foreach (var item in customers)
                            {
                                <div class="col-lg-4 col-md-6 col-12">
                                    <div class="card border border-secondary border-opacity-25 rounded-2 h-100">
                                        <div class="card-body d-flex align-items-center gap-3 p-3">
                                            <div class="rounded-circle bg-warning bg-opacity-10 border border-warning border-opacity-25 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px">
                                                <i class="ti ti-user text-warning"></i>
                                            </div>
                                            <div class="flex-grow-1 min-w-0">
                                                <p class="fw-semibold mb-0 text-truncate">@item.CustomeName @item.CustomeSurname</p>
                                                <small class="text-muted">@item.CustomeCity, @item.CustomeDistrict</small>
                                                <p class="mb-0 mt-1 fw-bold text-success">₺@item.CustomeBalance.ToString("N2")</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
