@using EntityFrameworkCore_MasterclassDashboard.Entities
@{
    ViewData["Title"] = "Sipariş İstatistikleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
 
}
@model List<Order>
<main id="content" class="content py-10">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="mb-6">
                    <h1 class="fs-3 mb-1">Sipariş İstatistikleri</h1>
                    <p class="text-muted mb-0">Sipariş tutarları, adet ve özet bilgileri.</p>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-lg-3 col-12">
                <div class="card p-4 bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-2 h-100">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md bg-primary text-white rounded-2">
                            <i class="ti ti-shopping-cart fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6 text-muted">Toplam Sipariş Sayısı</h2>
                            <h3 class="fw-bold mb-0">@ViewBag.totalOrderCount</h3>
                            <p class="text-primary mb-0 small">Bu dönem</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-12">
                <div class="card p-4 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-2 h-100">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md bg-success text-white rounded-2">
                            <i class="ti ti-currency-lira fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6 text-muted">Toplam Sipariş Tutarı</h2>
                            <h3 class="fw-bold mb-0">₺@ViewBag.totalOrderBalance</h3>
                            <p class="text-success mb-0 small">Toplam ciro</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-12">
                <div class="card p-4 bg-info bg-opacity-10 border border-info border-opacity-25 rounded-2 h-100">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md bg-info text-white rounded-2">
                            <i class="ti ti-chart-line fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6 text-muted">Ortalama Sipariş Tutarı</h2>
                            <h3 class="fw-bold mb-0">₺@ViewBag.avgOrderBalance</h3>
                            <p class="text-info mb-0 small">Sipariş başına</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-12">
                <div class="card p-4 bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-2 h-100">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md bg-warning text-white rounded-2">
                            <i class="ti ti-package fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6 text-muted">Toplam Satılan Adet</h2>
                            <h3 class="fw-bold mb-0">@ViewBag.totalOrderQuantity</h3>
                            <p class="text-warning mb-0 small">Satış adedi</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-lg-4 col-12">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between border-bottom pb-4 mb-3">
                            <div>
                                <h3 class="fw-bold h4 text-primary">₺@ViewBag.minOrderBalance</h3>
                                <span class="text-muted">Minimum Sipariş Tutarı</span>
                            </div>
                            <div>
                                <i class="ti ti-arrow-down-circle fs-1 text-primary"></i>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center small">
                            <span class="text-muted">En düşük sipariş tutarı</span>
                            <a href="#" class="link-primary text-decoration-underline">Detay</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-12">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between border-bottom pb-4 mb-3">
                            <div>
                                <h3 class="fw-bold h4 text-success">₺@ViewBag.maxOrderBalance</h3>
                                <span class="text-muted">Maksimum Sipariş Tutarı</span>
                            </div>
                            <div>
                                <i class="ti ti-arrow-up-circle fs-1 text-success"></i>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center small">
                            <span class="text-muted">En yüksek sipariş tutarı</span>
                            <a href="#" class="link-primary text-decoration-underline">Detay</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-12">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between border-bottom pb-4 mb-3">
                            <div>
                                <h3 class="fw-bold h4 text-info">₺@ViewBag.avgUnitPrice</h3>
                                <span class="text-muted">Ortalama Birim Fiyat</span>
                            </div>
                            <div>
                                <i class="ti ti-currency-lira fs-1 text-info"></i>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center small">
                            <span class="text-muted">Siparişler genelinde</span>
                            <a href="#" class="link-primary text-decoration-underline">Detay</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="icon-shape icon-sm bg-primary text-white rounded-2 d-inline-flex align-items-center justify-content-center">
                                <i class="ti ti-report-analytics"></i>
                            </span>
                            <div>
                                <h4 class="mb-0 h5">Sipariş Özeti</h4>
                                <small class="text-muted">Tutar, adet ve tarih bilgileri</small>
                            </div>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary rounded-2">
                            <i class="ti ti-filter me-1"></i> Filtrele
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col" class="ps-4">Sipariş No</th>
                                        <th scope="col">Birim Fiyat (₺)</th>
                                        <th scope="col">Satış Adedi</th>
                                        <th scope="col">Toplam Tutar (₺)</th>
                                        <th scope="col" class="pe-4 text-end">Tarih</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold">#@item.Id</td>
                                            <td>₺@item.UnitPrice.ToString("N2")</td>
                                            <td><span class="badge bg-light text-dark">@item.SaleCount</span></td>
                                            <td class="fw-semibold text-success">₺@item.TotalPrice.ToString("N2")</td>
                                            <td class="pe-4 text-end text-muted">@item.CreatedDate.ToString("dd MMM yyyy")</td>
                                        </tr>
                                    }
                                   

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
