@using EntityFrameworkCore_MasterclassDashboard.Entities
@{
    ViewData["Title"] = "Ürün İstatistikleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.categoryDistribution as Dictionary<string, int>;
    var products = ViewBag.latestOrderProduct as List<Order>;
}
   
<main id="content" class="content py-10">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="mb-6">
                    <h1 class="fs-3 mb-1">Ürün İstatistikleri</h1>
                    <p class="text-muted mb-0">Fiyat, stok ve kategori özeti.</p>
                </div>
            </div>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm overflow-hidden">
                    <div class="card-body p-0">
                        <div class="row g-0">
                            <div class="col-6 col-lg-3 border-end border-secondary border-opacity-25 p-4 text-center">
                                <i class="ti ti-package fs-2 text-primary d-block mb-2"></i>
                                <span class="d-block display-6 fw-bold text-primary">@ViewBag.productCount</span>
                                <small class="text-muted">Toplam Ürün</small>
                            </div>
                            <div class="col-6 col-lg-3 border-end border-secondary border-opacity-25 p-4 text-center">
                                <i class="ti ti-currency-lira fs-2 text-success d-block mb-2"></i>
                                <span class="d-block display-6 fw-bold text-success">₺@ViewBag.totalStockAmount</span>
                                <small class="text-muted">Stok Değeri</small>
                            </div>
                            <div class="col-6 col-lg-3 border-end border-secondary border-opacity-25 p-4 text-center">
                                <i class="ti ti-chart-line fs-2 text-info d-block mb-2"></i>
                                <span class="d-block display-6 fw-bold text-info">₺@ViewBag.avgOrderAmount</span>
                                <small class="text-muted">Ort. Fiyat</small>
                            </div>
                            <div class="col-6 col-lg-3 p-4 text-center">
                                <i class="ti ti-stack-2 fs-2 text-warning d-block mb-2"></i>
                                <span class="d-block display-6 fw-bold text-warning">@ViewBag.totalProductStock</span>
                                <small class="text-muted">Toplam Stok</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-lg-8 col-12">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm h-100">
                    <div class="card-body p-0">
                        <div class="p-4 border-bottom border-secondary border-opacity-25 bg-light bg-opacity-50">
                            <h5 class="mb-0 fw-bold"><i class="ti ti-chart-dots-2 me-2 text-primary"></i>Öne Çıkan Metrikler</h5>
                        </div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex align-items-center gap-3 border-0 border-start border-4 border-primary px-4 py-3">
                                
                                <div class="flex-grow-1">
                                    <span class="fw-semibold">En Düşük Ürün Fiyatı</span>
                                    <small class="d-block text-muted">Mağazadaki en düşük fiyatlı ürün</small>
                                </div>
                                <span class="text-primary fw-bold fs-4">₺@ViewBag.lowProductPrice</span>
                                <i class="ti ti-arrow-down-circle fs-3 text-primary opacity-75"></i>
                            </li>
                            <li class="list-group-item d-flex align-items-center gap-3 border-0 border-start border-4 border-success px-4 py-3">
                               
                                <div class="flex-grow-1">
                                    <span class="fw-semibold">En Yüksek Ürün Fiyatı</span>
                                    <small class="d-block text-muted">Mağazadaki en yüksek fiyatlı ürün</small>
                                </div>
                                <span class="text-success fw-bold fs-4">₺@ViewBag.highProductPrice</span>
                                <i class="ti ti-arrow-up-circle fs-3 text-success opacity-75"></i>
                            </li>
                            <li class="list-group-item d-flex align-items-center gap-3 border-0 border-start border-4 border-danger px-4 py-3">
                                
                                <div class="flex-grow-1">
                                    <span class="fw-semibold">En Düşük Stok Miktarı</span>
                                    <small class="d-block text-muted">Acil yenilenmesi gereken kritik envanter seviyesi</small>
                                </div>
                                <span class="text-danger fw-bold fs-4">@ViewBag.lowProductStock</span>
                                <i class="ti ti-alert-triangle fs-3 text-danger opacity-75"></i>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-12">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-category-2 me-2 text-info"></i>En yüksek 5 Kategori Dağılımı</h5>
                    </div>
                    <div class="card-body p-3">
                        @foreach(var item in categories)
                        {
                            <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-secondary border-opacity-25">
                                <span class="text-muted">@item.Key</span>
                                <span class="badge bg-primary rounded-pill">@item.Value</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center border-bottom border-secondary border-opacity-25 px-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="ti ti-grid-dots me-2 text-primary"></i>Ürün Özeti</h5>
                        <button class="btn btn-sm btn-outline-secondary rounded-2"><i class="ti ti-filter me-1"></i>Filtrele</button>
                    </div>
                    <div class="card-body p-3">
        <div class="row g-3">

                            @foreach(var item in products)
                            {
                                <div class="col-lg-4 col-md-6 col-12">
                                    <div class="card border border-secondary border-opacity-25 rounded-2 shadow-sm h-100">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="fw-semibold mb-0 text-truncate pe-2">@item.Product.ProductName</h6>
                                                <span class="badge bg-@(item.Product.IsActive ? "success" : "danger") rounded-pill">@(item.Product.IsActive ? "Aktif" : "Pasif")</span>
                                            </div>
                                            <p class="mb-2 fs-5 fw-bold text-primary">₺@item.Product.ProductPrice</p>
                                            <div class="d-flex justify-content-between align-items-center small">
                                                <span class="text-muted">@item.Product.Category.CategoryName</span>
                                                <span class="badge bg-light text-dark border">@item.Product.ProductStock stok</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>